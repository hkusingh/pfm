# ─── Database ────────────────────────────────────────────────────────────────
# Production: use the Neon pooled connection string
# Local dev: the Docker Compose Postgres instance below
DATABASE_URL=postgresql://pfm:pfm@localhost:5432/pfm_dev
DATABASE_URL_TEST=postgresql://pfm:pfm@localhost:5432/pfm_test

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Minimum 32 characters — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars-long

# ─── Encryption ───────────────────────────────────────────────────────────────
# 32-byte hex key for at-rest encryption of MFA secrets and uploaded files
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=change-me-32-byte-hex-encryption-key-here-replace

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Provider-agnostic SMTP — used for password reset, invites, email verification,
# and MFA codes. Works with Mailtrap, Amazon SES, Postmark, etc.
# If SMTP_HOST / SMTP_USER / SMTP_PASS are not all set, emails are logged to
# stdout instead of being sent (dev mode only).
#
# Mailtrap — Email Testing (sandbox, captures mail, no domain needed):
#   SMTP_HOST=sandbox.smtp.mailtrap.io   SMTP_PORT=2525   SMTP_USER/PASS=<inbox creds>
# Mailtrap — Email Sending (live delivery, requires a verified sending domain):
#   SMTP_HOST=live.smtp.mailtrap.io      SMTP_PORT=587    SMTP_USER=api   SMTP_PASS=<token>
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
# The address mail is sent from. For live sending it must be on a verified domain.
EMAIL_FROM=noreply@thesmartmunshi.com

# ─── File Storage (Google Cloud Storage) ──────────────────────────────────────
# Uploaded statement files are stored encrypted in GCS
GCS_BUCKET=pfm-statements-dev
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ─── Web ──────────────────────────────────────────────────────────────────────
WEB_ORIGIN=http://localhost:5173

# ─── App name (brand) ─────────────────────────────────────────────────────────
# The user-facing product name. Set in BOTH places (api reads PUBLIC_APP_NAME;
# web inlines VITE_PUBLIC_APP_NAME at build time). Do NOT hardcode it elsewhere.
PUBLIC_APP_NAME=Smart Munshi
VITE_PUBLIC_APP_NAME=Smart Munshi

# ─── Feature gate ─────────────────────────────────────────────────────────────
# Set to true in production to enforce invite-only signup, email verification,
# and mandatory MFA. Leave false (or unset) for local development.
AUTH_GATE=true
