# ─── Database ────────────────────────────────────────────────────────────────
# Production: use the Neon pooled connection string
# Local dev: the Docker Compose Postgres instance below
DATABASE_URL=postgresql://pfm:pfm@localhost:5432/pfm_dev
DATABASE_URL_TEST=postgresql://pfm:pfm@localhost:5432/pfm_test

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Minimum 32 characters — generate with: openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars-long

# ─── Encryption ───────────────────────────────────────────────────────────────
# 32-byte hex key for at-rest encryption of MFA secrets and uploaded files
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=change-me-32-byte-hex-encryption-key-here-replace

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get your API key at https://resend.com — used for email verification + MFA codes
# If not set, emails are logged to stdout (dev mode only)
RESEND_API_KEY=re_your_api_key_here
# The domain emails are sent from — must be verified in Resend dashboard
EMAIL_DOMAIN=yourdomain.com

# ─── File Storage (Google Cloud Storage) ──────────────────────────────────────
# Uploaded statement files are stored encrypted in GCS
GCS_BUCKET=pfm-statements-dev
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ─── Web ──────────────────────────────────────────────────────────────────────
WEB_ORIGIN=http://localhost:5173

# ─── App name ─────────────────────────────────────────────────────────────────
# Single source of truth — do NOT hardcode the product name anywhere else
PUBLIC_APP_NAME=PFM

# ─── Feature gate ─────────────────────────────────────────────────────────────
# Set to true in production to enforce invite-only signup, email verification,
# and mandatory MFA. Leave false (or unset) for local development.
AUTH_GATE=true
