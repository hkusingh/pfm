{
  "name": "@pfm/db",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "build": "tsc",
    "generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:test": "DATABASE_URL=$DATABASE_URL_TEST prisma migrate deploy",
    "seed": "tsx prisma/seed.ts",
    "seed:demo": "SEED_DEMO=true tsx prisma/seed-demo.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "@pfm/config": "workspace:*",
    "@pfm/core": "workspace:*",
    "@types/node": "^22.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
