// PFM data model — Epic E0.2
// Money stored in integer minor units (cents) + explicit currency.
// Visibility enforced at the application layer via resolveScope (@pfm/core).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String
  name            String
  emailVerifiedAt DateTime?
  isSiteAdmin     Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  mfaMethods      MfaMethod[]
  recoveryCodes   RecoveryCode[]
  sessions        Session[]
  trustedDevices  TrustedDevice[]
  memberships     Membership[]
  invitesSent     Invite[]         @relation("InvitedBy")
  accounts        Account[]
  importBatches   ImportBatch[]
  auditLogs       AuditLog[]
  categoryRules   CategoryRule[]
  signupInvites   SignupInvite[]
  savedCharts     SavedChart[]
}

model Session {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TrustedDevice {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── MFA ──────────────────────────────────────────────────────────────────────

enum MfaType {
  totp
  email
}

model MfaMethod {
  id          String    @id @default(cuid())
  userId      String
  type        MfaType
  // Encrypted at rest (AES-256-GCM via ENCRYPTION_KEY env)
  secret      String
  isPrimary   Boolean   @default(false)
  confirmedAt DateTime?
  createdAt   DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RecoveryCode {
  id       String    @id @default(cuid())
  userId   String
  codeHash String
  usedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Household ────────────────────────────────────────────────────────────────

model Household {
  id            String   @id @default(cuid())
  name          String
  baseCurrency  String   @default("USD")
  // Day of month when the budget period starts (1–28)
  monthStartDay Int      @default(1)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships    Membership[]
  invites        Invite[]
  accounts       Account[]
  categories     Category[]
  categoryRules  CategoryRule[]
  transferRoutes TransferRoute[]
  budgets        Budget[]
  sinkingFunds   SinkingFund[]
  importBatches  ImportBatch[]
  columnMappings ColumnMapping[]
  auditLogs      AuditLog[]
  savedCharts    SavedChart[]
}

enum MemberRole {
  owner
  member
}

enum MemberStatus {
  active
  removed
}

model Membership {
  id              String       @id @default(cuid())
  householdId     String
  userId          String
  role            MemberRole
  isPrimaryOwner  Boolean      @default(false)
  status          MemberStatus @default(active)
  joinedAt        DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([householdId, userId])
  @@index([userId])
}

enum InviteStatus {
  pending
  accepted
  revoked
}

model Invite {
  id              String       @id @default(cuid())
  householdId     String
  email           String
  role            MemberRole
  token           String       @unique
  expiresAt       DateTime
  status          InviteStatus @default(pending)
  invitedByUserId String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  invitedBy User      @relation("InvitedBy", fields: [invitedByUserId], references: [id])

  @@index([householdId])
  @@index([email])
}

// ─── Accounts ─────────────────────────────────────────────────────────────────

enum AccountType {
  checking
  savings
  credit_card
  investment
  loan
  mortgage
  other
}

enum AccountSource {
  manual
  import
  // plaid reserved for Phase 2
}

enum Visibility {
  shared
  private
  balance_only
}

model Account {
  id           String        @id @default(cuid())
  householdId  String
  ownerUserId  String?
  // Encrypted at rest (AES-256-GCM via EncryptionService, context = householdId)
  name         String
  type         AccountType
  source       AccountSource @default(manual)
  institution  String?
  // Last 4 digits of account number
  mask         String?
  // Encrypted; was Int — use EncryptionService to read/write
  balanceMinor  String
  balanceAsOf   DateTime?
  currency      String        @default("USD")
  visibility   Visibility    @default(shared)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  household                   Household       @relation(fields: [householdId], references: [id], onDelete: Cascade)
  owner                       User?           @relation(fields: [ownerUserId], references: [id])
  transactions                Transaction[]
  importBatches               ImportBatch[]
  transferRoutesAsSource      TransferRoute[] @relation("RouteSource")
  transferRoutesAsCounterpart TransferRoute[] @relation("RouteCounterpart")
  awaitingTransfers           Transaction[]   @relation("AwaitingCounterpart")

  @@index([householdId])
  @@index([ownerUserId])
}

// ─── Transactions ─────────────────────────────────────────────────────────────

model Transaction {
  id                 String    @id @default(cuid())
  accountId          String
  postedDate         DateTime  @db.Date
  // Encrypted at rest (AES-256-GCM via EncryptionService, context = householdId)
  merchant           String?
  merchantNormalized String?
  // HMAC-SHA256 of merchantNormalized — plaintext, used for category rule matching
  merchantRuleHash   String?
  // Encrypted; was Int — use EncryptionService to read/write
  amountMinor        String
  currency           String    @default("USD")
  categoryId         String?
  // SHA-256 of account+date+plaintext-amount+plaintext-merchantNormalized — prevents duplicate imports
  dedupHash          String
  sinkingFundId      String?
  isReserveFunded    Boolean   @default(false)
  importBatchId      String?
  // Reserved for Phase 2 (search/filter tag)
  tag                String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  hasSplit           Boolean   @default(false)
  isExcluded         Boolean   @default(false)

  // Transfer linking — see docs/transfer-linking-design.md
  awaitingCounterpartAccountId String?
  externalTransfer             Boolean   @default(false) // true when routed to "External / not tracked"

  account              Account            @relation(fields: [accountId], references: [id], onDelete: Cascade)
  category             Category?          @relation(fields: [categoryId], references: [id])
  sinkingFund          SinkingFund?       @relation(fields: [sinkingFundId], references: [id])
  importBatch          ImportBatch?       @relation(fields: [importBatchId], references: [id])
  splits               TransactionSplit[]
  transferPairAsDebit  TransferPair?      @relation("DebitSide")
  transferPairAsCredit TransferPair?      @relation("CreditSide")
  awaitingCounterpart  Account?           @relation("AwaitingCounterpart", fields: [awaitingCounterpartAccountId], references: [id], onDelete: SetNull)

  @@unique([accountId, dedupHash])
  @@index([accountId])
  @@index([categoryId])
  @@index([postedDate])
  @@index([awaitingCounterpartAccountId])
}

// ─── Transfer Linking ─────────────────────────────────────────────────────────

// Links the debit side to the credit side of a tracked inter-account transfer.
model TransferPair {
  id         String   @id @default(cuid())
  debitTxId  String   @unique
  creditTxId String   @unique
  createdAt  DateTime @default(now())

  debitTx  Transaction @relation("DebitSide",  fields: [debitTxId],  references: [id], onDelete: Cascade)
  creditTx Transaction @relation("CreditSide", fields: [creditTxId], references: [id], onDelete: Cascade)
}

// Remembers the user's routing decision for a transfer merchant pattern in a given account.
// Applied automatically on future imports so the user is only prompted once per pattern.
model TransferRoute {
  id                   String   @id @default(cuid())
  householdId          String
  sourceAccountId      String
  merchantMatch        String   // substring match against merchantNormalized
  counterpartAccountId String?  // null = external / untracked
  createdAt            DateTime @default(now())

  household          Household @relation(fields: [householdId],          references: [id], onDelete: Cascade)
  sourceAccount      Account   @relation("RouteSource",      fields: [sourceAccountId],      references: [id], onDelete: Cascade)
  counterpartAccount Account?  @relation("RouteCounterpart", fields: [counterpartAccountId], references: [id], onDelete: SetNull)

  @@unique([sourceAccountId, merchantMatch])
  @@index([householdId])
}

// ─── Categories ───────────────────────────────────────────────────────────────

enum CategoryKind {
  expense
  income
  transfer
}

model Category {
  id          String       @id @default(cuid())
  householdId String
  parentId    String?
  name        String
  color       String?
  sortOrder   Int          @default(0)
  // System categories (e.g. Income) cannot be deleted
  isSystem    Boolean      @default(false)
  kind        CategoryKind @default(expense)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  household    Household      @relation(fields: [householdId], references: [id], onDelete: Cascade)
  parent       Category?      @relation("CategoryParent", fields: [parentId], references: [id])
  children     Category[]     @relation("CategoryParent")
  transactions Transaction[]
  splits       TransactionSplit[]
  rules        CategoryRule[]
  budgets      Budget[]
  sinkingFunds SinkingFund[]

  @@index([householdId])
  @@index([parentId])
}

model TransactionSplit {
  id            String       @id @default(cuid())
  transactionId String
  categoryId    String?
  amountMinor   Int

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  category    Category?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([transactionId])
}

model CategoryRule {
  id              String   @id @default(cuid())
  householdId     String
  // Substring match against merchantNormalized
  merchantMatch   String
  categoryId      String
  createdByUserId String
  createdAt       DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdBy User      @relation(fields: [createdByUserId], references: [id])

  @@index([householdId])
}

// ─── Budgets ──────────────────────────────────────────────────────────────────

model Budget {
  id          String   @id @default(cuid())
  householdId String
  categoryId  String
  // Month key, e.g. "2026-06"
  period      String
  amountMinor Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  category  Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([householdId, categoryId, period])
  @@index([householdId, period])
}

// ─── Sinking Funds ────────────────────────────────────────────────────────────

enum SinkingFundCadence {
  annual
  semi
  quarterly
}

enum SinkingFundMethod {
  amortized
  actual
}

enum SinkingFundStartMode {
  gradual
  frontload
}

model SinkingFund {
  id                  String               @id @default(cuid())
  householdId         String
  categoryId          String
  cadence             SinkingFundCadence
  totalMinor          Int
  nextDueDate         DateTime             @db.Date
  method              SinkingFundMethod    @default(amortized)
  reserveBalanceMinor Int                  @default(0)
  startMode           SinkingFundStartMode @default(gradual)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  household    Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  category     Category      @relation(fields: [categoryId], references: [id])
  transactions Transaction[]

  @@index([householdId])
}

// ─── Import ───────────────────────────────────────────────────────────────────

enum ImportStatus {
  pending
  processing
  done
  failed
}

model ImportBatch {
  id             String       @id @default(cuid())
  householdId    String
  accountId      String?
  uploaderUserId String
  importedCount  Int          @default(0)
  skippedCount   Int          @default(0)
  status         ImportStatus @default(pending)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  household    Household     @relation(fields: [householdId], references: [id], onDelete: Cascade)
  account      Account?      @relation(fields: [accountId], references: [id])
  uploader     User          @relation(fields: [uploaderUserId], references: [id])
  files        ImportFile[]
  transactions Transaction[]

  @@index([householdId])
}

model ImportFile {
  id                String   @id @default(cuid())
  importBatchId     String
  // Encrypted path in GCS
  storageKey        String
  // SHA-256 of filename+size+first-row — used to recall column mappings
  sourceFingerprint String
  // Encrypted at rest (AES-256-GCM via EncryptionService, context = householdId)
  originalName      String
  createdAt         DateTime @default(now())

  importBatch ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  @@index([importBatchId])
}

model ColumnMapping {
  id                String   @id @default(cuid())
  householdId       String
  // Matches ImportFile.sourceFingerprint
  sourceFingerprint String
  // JSON: { date: string; merchant: string; amount: string; }
  mapping           Json
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  @@unique([householdId, sourceFingerprint])
}

// ─── Platform access (Epic 8) ─────────────────────────────────────────────────

enum RegistrationMode {
  admin_invite
  beta_invite
  open
}

model RegistrationPolicy {
  id                   Int              @id @default(1)
  mode                 RegistrationMode @default(admin_invite)
  householdInviteQuota Int              @default(5)
  updatedAt            DateTime         @updatedAt
  updatedBy            String?
}

model SignupInvite {
  id                  String    @id @default(cuid())
  email               String
  token               String    @unique
  expiresAt           DateTime
  usedAt              DateTime?
  issuedByAdminId     String
  // Set only in beta_invite mode when a household issues the invite
  issuedByHouseholdId String?
  createdAt           DateTime  @default(now())

  issuedByAdmin User @relation(fields: [issuedByAdminId], references: [id])

  @@index([email])
  @@index([token])
}

// ─── Saved charts (Reports / Dashboard) ──────────────────────────────────────

model SavedChart {
  id          String   @id @default(cuid())
  householdId String
  creatorId   String
  name        String
  // bar | line | donut | stacked_bar
  chartType   String
  // spending | income | count
  measure     String
  // category | merchant | month
  groupBy     String
  // 3m | 6m | 12m | ytd
  dateRange   String
  // net_worth_trend | income_vs_expenses | cash_flow | spending_by_category
  reportKey   String?
  accountId   String?
  categoryId  String?
  // household | personal
  view        String   @default("household")
  isShared    Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  creator   User      @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  @@index([householdId])
}

// ─── Audit ────────────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(cuid())
  householdId String
  actorUserId String
  action      String
  targetType  String
  targetId    String
  // Arbitrary metadata (before/after values, etc.)
  metadata    Json?
  createdAt   DateTime @default(now())

  household Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  actor     User      @relation(fields: [actorUserId], references: [id])

  @@index([householdId, createdAt])
  @@index([actorUserId])
}
