# Dependencies
node_modules/
.pnp/
vendor/
__pycache__/
*.py[cod]
.venv/
venv/

# Build output
dist/
build/
out/
*.tsbuildinfo
# Prevent compiled JS/declarations leaking into src/ (packages emit to dist/)
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts
packages/*/src/**/*.d.ts.map

# Environment & secrets
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Editor / OS
.idea/
.vscode/*
!.vscode/extensions.json
.DS_Store
Thumbs.db

# Test / coverage
coverage/
.nyc_output/

# Turbo local cache
.turbo/

# Claude Code settings (local)
.claude/

# Temp
*.tmp
tmp/

# Office lock/owner temp files
~$*

# Local statement upload storage (dev-only, Phase 1)
apps/api/uploads/
